    "@types/react": "~18.2.79",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^7.0.0",
    "prettier": "^3.3.0",
    "typescript": "~5.3.3"
