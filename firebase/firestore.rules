rules_version = '2';

// Duet Firestore rules — couple isolation is the core invariant.
// A document under couples/{coupleId}/** is readable/writable only by the
// authenticated members of that couple.
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers are defined INSIDE the match block so the `database` path
    // variable is in scope for exists()/get() path references.
    function signedIn() {
      return request.auth != null;
    }

    // Membership is read from the couple doc's memberIds array.
    function isMember(coupleId) {
      return signedIn()
        && exists(/databases/$(database)/documents/couples/$(coupleId))
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberIds;
    }

    // ---- Users: a user reads/writes only their own profile; partner can read. ----
    match /users/{uid} {
      allow read: if signedIn();              // partner needs to read profile fields
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && request.auth.uid == uid
                    && request.resource.data.uid == uid;
      allow delete: if false;
    }

    // ---- Couples ----
    match /couples/{coupleId} {
      // Members can read. A PENDING couple (1 member, awaiting a partner) is
      // also readable by any signed-in user so an invitee can accept — they
      // need the random coupleId (from a valid invite) to find it anyway.
      allow read: if isMember(coupleId)
                  || (signedIn() && resource.data.memberIds.size() == 1);
      // create allowed by the creator listing themselves as the sole member
      allow create: if signedIn()
                    && request.auth.uid in request.resource.data.memberIds
                    && request.resource.data.memberIds.size() <= 2;
      // Normal member edits.
      allow update: if isMember(coupleId)
                    && request.resource.data.memberIds.size() <= 2;
      // JOIN: a signed-in non-member adds themselves to a 1-member couple,
      // preserving the existing member. This is the invite-acceptance path.
      allow update: if signedIn()
                    && resource.data.memberIds.size() == 1
                    && request.resource.data.memberIds.size() == 2
                    && resource.data.memberIds[0] in request.resource.data.memberIds
                    && request.auth.uid in request.resource.data.memberIds;
      // A member may dissolve the couple (the "remove partner" wipe). The
      // initiator deletes subcollections first (while still a member), then the
      // couple doc last.
      allow delete: if isMember(coupleId);

      // ---- All couple subcollections: members only ----
      // NOTE on capsules (F3): a recursive wildcard can't also enforce
      // "no reading before unlock" — under Firestore's union semantics this
      // broad grant would win. So capsule SECRECY is enforced by ENCRYPTION:
      // `bodyCipher` is ciphertext and the decryption key is released by the
      // server only at unlock. A member can read the doc but not decrypt it,
      // and flipping `unlocked` client-side is harmless without the key.
      match /{document=**} {
        allow read, write: if isMember(coupleId);
      }
    }

    // ---- Invites: anyone signed-in can look up a code to join; creator manages. ----
    match /invites/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      // A joiner (not the creator) must be able to flip `consumed` when accepting.
      allow update: if signedIn();
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }

    // ---- Global game content: read-only to clients, writes via admin only. ----
    match /gameContent/{doc=**} { allow read: if signedIn(); allow write: if false; }
    match /wheelRewards/{doc}    { allow read: if signedIn(); allow write: if false; }

    // Default deny.
    match /{document=**} { allow read, write: if false; }
  }
}
