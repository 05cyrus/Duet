# ─────────────────────────────────────────────────────────────
# Firebase (Spark / free plan).  Client config is NOT secret — these
# EXPO_PUBLIC_ vars are bundled into the app. Real protection comes from
# Firestore / RTDB / Storage security rules + App Check.
# ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=

# Google Sign-In (free) — OAuth client IDs from Google Cloud console
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# ─────────────────────────────────────────────────────────────
# AI provider keys — ALL have free tiers. Stored ONLY as Cloud Functions
# secrets (firebase functions:secrets:set), NEVER shipped in the app.
# The values below are placeholders for local emulator use only.
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=

EAS_PROJECT_ID=
